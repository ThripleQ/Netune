+Element theme_selection(Element e) {
+    auto &t = ThemeManager::instance().current();
+    if (t.accent_bg.has_color) {
+        e = e | bgcolor(Color::RGB(t.accent_bg.r, t.accent_bg.g, t.accent_bg.b));
