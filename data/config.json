{
  "version": "1.0",
  "_comment": "LMusic v2.0 全局配置 — 所有设置集中于此",

  "audio": {
    "backend": "auto",
    "sample_rate": 44100,
    "channels": 2,
    "bits_per_sample": 16,
    "buffer_frames": 4096,
    "volume": 80,
    "device": "default"
  },

  "playback": {
    "loop_mode": 0,
    "gapless": true,
    "crossfade_sec": 0,
    "resume_on_startup": false,
    "seek_step_sec": 5
  },

  "ui": {
    "theme": "default",
    "layout": "data/layouts/default.yaml",
    "keybindings": "default",
    "show_lyric": true,
    "show_cover": false,
    "show_status_bar": true
  },

  "music_sources": {
    "local": {
      "enabled": true,
      "dirs": ["/home/liu/Music/pop", "/home/liu/Music/rock", "/home/liu/Music/jazz"],
      "recursive": true,
      "show_hidden": false
    },
    "netease": {
      "enabled": true,
      "quality": "standard",
      "cookie_file": "",
      "auto_login": false
    }
  },

  "network": {
    "proxy": "",
    "timeout_sec": 10,
    "max_retries": 2,
    "user_agent": "LMusic/2.0"
  },

  "plugins": {
    "decoders": {
      "preferred": ["dr_mp3", "dr_flac", "dr_wav"]
    },
    "audio_outputs": {
      "preferred": ["alsa", "pulseaudio", "sdl"]
    }
  }
}
